# ═══════════════════════════════════════════════════════════════════════
# AlgoBuddy — Environment Configuration Reference
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════════════

# ──────────── Spring Boot Backend (Optional) ────────────
# Set to 'true' to route requests to the Java Spring Boot API locally
NEXT_PUBLIC_USE_SPRING_BOOT_API=false
NEXT_PUBLIC_SPRING_BOOT_API_URL=http://localhost:8080

# ──────────── Supabase (Required) ────────────
# Get these from your Supabase project dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ──────────── Cloudflare Turnstile Captcha (Optional) ────────────
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
# In dev, you can use 1x00000000000000000000AA as site key and bypass locally
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# Set to 'true' to bypass CAPTCHA verification locally
TURNSTILE_BYPASS=true

# ──────────── Email (Nodemailer via Gmail) ────────────
EMAIL_USER=your-email@gmail.com
# Use a Gmail App Password (not your account password):
# https://support.google.com/accounts/answer/185833
EMAIL_PASSWORD=your-google-app-password
REVIEW_INBOX_EMAIL=optional-inbox@gmail.com

# ──────────── AI Chatbot (Google Gemini) ────────────
# Required for the AI assistant feature.
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ──────────── Google Analytics ────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ──────────── Rate Limiting (Upstash Redis) ────────────
# Required in production for distributed rate limiting.
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token
RATE_LIMIT_MAX=10

# ──────────── UI Feature Flags ────────────
NEXT_PUBLIC_SHOW_COMMUNITY_BADGE=true
AUTO_CONFIRM_EMAIL=true

# ──────────── CSRF Protection ────────────
# Generate a secure random string (e.g., run `openssl rand -hex 32`).
# Required in production; a dev-only fallback is used if omitted locally.
CSRF_SECRET=your-csrf-secret-key

# ──────────── Arena Socket Server ────────────
# Redis URL for arena matchmaking and session state
# Use "rediss://" prefix for SSL (e.g. Upstash)
REDIS_URL=redis://localhost:6379

# ──────────── Debug / Development Flags ────────────
# TURNSTILE_BYPASS=true
# DISABLE_RATE_LIMIT=true
# REDIS_REQUIRED=false

# Local Development Overrides — only uncomment if needed:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_SSL=false
# SOCKET_SERVER_URL=http://localhost:4000
# DEBUG_ENABLED=false
# DEBUG_KEY=your-secure-debug-key

